# Backend environment variables
# Copy to server/.env and fill in values

# SQLite database file path
# Local development:
DATABASE_URL=file:./data/fmn.db
# On Render (persistent disk mounted at /var/data):
# DATABASE_URL=file:/var/data/fmn.db

# Server port (Render sets this automatically)
PORT=5000

# JWT signing secret (required – use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Public URL of the frontend (used in confirmation emails)
SITE_URL=https://fmn-news.onrender.com

# VAPID keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# SMTP settings for newsletter emails (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password

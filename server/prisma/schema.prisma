generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model admin {
  id           String @id
  username     String @unique(map: "Admin_username_key")
  passwordHash String
  role         String @default("admin")
}

model article {
  id                String    @id
  title             String
  excerpt           String
  content           String
  category          String
  author            String
  image             String
  time              String
  readTime          String?
  featured          Boolean   @default(false)
  isBreaking        Boolean   @default(false)
  views             Int       @default(0)
  tags              String?
  publishAt         DateTime?
  status            String    @default("published")
  articleType       String?   @default("News")
  dateline          String?
  imageCaption      String?
  imageCredit       String?
  correction        String?
  editedBy          String?
  series            String?
  seriesPart        Int?
  seriesTotal       Int?
  factCheckVerdict  String?
  lastVerified      DateTime?
  aboutArticle      String?
  sources           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  comment           comment[]
  authorRel         author?   @relation(fields: [authorId], references: [id])
  authorId          String?
}

model breakingnews {
  id   Int    @id @default(autoincrement())
  text String
}

model comment {
  id        String    @id
  author    String
  content   String
  upvotes   Int       @default(0)
  createdAt DateTime  @default(now())
  articleId String
  parentId  String?
  article   article   @relation(fields: [articleId], references: [id], onDelete: Cascade, map: "Comment_articleId_fkey")
  parent    comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   comment[] @relation("CommentReplies")

  @@index([articleId], map: "Comment_articleId_fkey")
  @@index([parentId])
}

model liveblog {
  id        String           @id
  articleId String           @unique
  title     String
  isLive    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updates   liveblogupdate[]
}

model liveblogupdate {
  id         String   @id
  liveblogId String
  content    String
  label      String?
  isPinned   Boolean  @default(false)
  timestamp  DateTime @default(now())
  liveblog   liveblog @relation(fields: [liveblogId], references: [id], onDelete: Cascade)

  @@index([liveblogId])
}

model trendingtopic {
  id    String @id
  tag   String
  count String
  size  String
}

model videostory {
  id       String  @id
  title    String
  duration String
  image    String
  url      String?
}

model author {
  id        String    @id
  name      String
  bio       String?
  avatar    String?
  title     String?
  twitter   String?
  website   String?
  email     String?
  createdAt DateTime  @default(now())
  articles  article[]
}

model subscriber {
  id        String   @id
  email     String   @unique
  confirmed Boolean  @default(false)
  token     String?
  createdAt DateTime @default(now())
}

model pushsubscription {
  id        String   @id
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

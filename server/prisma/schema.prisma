generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id           String @id
  username     String @unique(map: "Admin_username_key") @db.VarChar(50)
  passwordHash String @db.VarChar(255)
  role         String @default("admin") @db.VarChar(20)
}

model article {
  id         String    @id
  title      String    @db.VarChar(255)
  excerpt    String    @db.Text
  content    String    @db.LongText
  category   String    @db.VarChar(50)
  author     String    @db.VarChar(100)
  image      String    @db.LongText
  time       String    @db.VarChar(50)
  readTime   String?   @db.VarChar(50)
  featured   Boolean   @default(false)
  isBreaking Boolean   @default(false)
  views      Int       @default(0)
  tags         String?   @db.VarChar(500)
  publishAt    DateTime?
  status       String    @default("published") @db.VarChar(20)
  articleType  String?   @default("News") @db.VarChar(50)
  dateline     String?   @db.VarChar(100)
  imageCaption String?   @db.Text
  imageCredit  String?   @db.VarChar(200)
  correction   String?   @db.Text
  editedBy     String?   @db.VarChar(100)
  series       String?   @db.VarChar(200)
  seriesPart        Int?
  seriesTotal       Int?
  factCheckVerdict  String?   @db.VarChar(20)
  lastVerified      DateTime?
  aboutArticle      String?   @db.Text
  sources           String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt    DateTime
  comment      comment[]
  authorRel    author?   @relation(fields: [authorId], references: [id])
  authorId     String?

  @@fulltext([title, content, excerpt])
}

model breakingnews {
  id   Int    @id @default(autoincrement())
  text String @db.Text
}

model comment {
  id        String    @id
  author    String    @db.VarChar(100)
  content   String    @db.Text
  upvotes   Int       @default(0)
  createdAt DateTime  @default(now())
  articleId String
  parentId  String?
  article   article   @relation(fields: [articleId], references: [id], onDelete: Cascade, map: "Comment_articleId_fkey")
  parent    comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   comment[] @relation("CommentReplies")

  @@index([articleId], map: "Comment_articleId_fkey")
  @@index([parentId])
}

model liveblog {
  id        String           @id
  articleId String           @unique
  title     String           @db.VarChar(255)
  isLive    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updates   liveblogupdate[]
}

model liveblogupdate {
  id         String   @id
  liveblogId String
  content    String   @db.Text
  label      String?  @db.VarChar(100)
  isPinned   Boolean  @default(false)
  timestamp  DateTime @default(now())
  liveblog   liveblog @relation(fields: [liveblogId], references: [id], onDelete: Cascade)

  @@index([liveblogId])
}

model trendingtopic {
  id    String @id
  tag   String @db.VarChar(100)
  count String @db.VarChar(20)
  size  String @db.VarChar(20)
}

model videostory {
  id       String  @id
  title    String  @db.VarChar(255)
  duration String  @db.VarChar(20)
  image    String  @db.LongText
  url      String? @db.LongText
}

model author {
  id        String    @id
  name      String    @db.VarChar(100)
  bio       String?   @db.Text
  avatar    String?   @db.VarChar(500)
  title     String?   @db.VarChar(100)
  twitter   String?   @db.VarChar(200)
  website   String?   @db.VarChar(200)
  email     String?   @db.VarChar(200)
  createdAt DateTime  @default(now())
  articles  article[]
}

model subscriber {
  id        String   @id
  email     String   @unique @db.VarChar(255)
  confirmed Boolean  @default(false)
  token     String?  @db.VarChar(255)
  createdAt DateTime @default(now())
}

model pushsubscription {
  id        String   @id
  endpoint  String   @db.Text
  p256dh    String   @db.VarChar(500)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now())
}
